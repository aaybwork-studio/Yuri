<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link rel="canonical" href="{{ canonical_url }}">
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}
    <title>{{ shop.name }}</title>
    {{ content_for_header }}
    {{ 'dia-regular.woff' | asset_url | preload_tag: as: 'font', type: 'font/woff', crossorigin: 'anonymous' }}
    {{ 'yuri-styles.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'yuri-scripts.js' | asset_url }}" defer="defer"></script>
  </head>
  <body class="bg-[#faf8f1] text-black font-sans min-h-screen flex flex-col justify-between">
    <main id="MainContent" class="flex-grow flex items-center justify-center p-6" role="main">
      {{ content_for_layout }}
    </main>
  </body>
</html>
