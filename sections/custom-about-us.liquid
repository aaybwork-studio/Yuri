<div class="color-{{ section.settings.color_scheme }} gradient" style="background-color: var(--color-warm-white);">
  <div class="yuri-about-container border-b zen-border">
    
    {%- comment -%}Left Side: Styled Content Box{%- endcomment -%}
    <div class="flex-1 flex flex-col justify-center items-center px-8 py-16 md:px-20 md:py-24" 
         style="background-color: {{ section.settings.bg_color }};">
      <div class="max-w-[480px]">
        {%- if section.settings.subheading != blank -%}
          <p class="font-sans text-sage text-xs uppercase tracking-widest mb-4" style="color: var(--color-sage); letter-spacing: 0.15em;">
            {{ section.settings.subheading | escape }}
          </p>
        {%- endif -%}
        
        {%- if section.settings.heading != blank -%}
          <h2 class="font-serif text-forest text-3xl md:text-5xl font-light mb-6 lowercase" 
              style="color: var(--color-forest); font-family: var(--font-serif); line-height: 1.2;">
            {{ section.settings.heading | escape }}
          </h2>
        {%- endif -%}
        
        {%- if section.settings.text != blank -%}
          <div class="font-sans text-sage text-sm md:text-base leading-relaxed mb-8" style="color: var(--color-sage);">
            {{ section.settings.text }}
          </div>
        {%- endif -%}
        
        {%- if section.settings.btn_label != blank and section.settings.btn_link != blank -%}
          <a href="{{ section.settings.btn_link }}" class="button button--secondary">
            {{ section.settings.btn_label | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>
    
    {%- comment -%}Right Side: Full-height image{%- endcomment -%}
    <div class="flex-1 min-h-[40vh] md:min-h-screen relative overflow-hidden">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1500 | image_tag:
          class: 'absolute inset-0 w-full h-full object-cover',
          loading: 'lazy'
        }}
      {%- else -%}
        <img src="{{ 'yuri-about.png' | asset_url }}" class="absolute inset-0 w-full h-full object-cover" alt="YURI Zen About Us" loading="lazy">
      {%- endif -%}
    </div>
    
  </div>
</div>

{% schema %}
{
  "name": "Yuri About Split",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Text Side Background Color",
      "default": "#f4efe6"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "a new standard in atmosphere"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "yuri blends tranquility with luxury."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>our meticulously hand-poured soy candles and fragrance diffusers restore harmony and clarity to your living space. rooted in organic zen styling, yuri brings nature into your home.</p>"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "explore our story"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link",
      "default": "/pages/about"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Brand Image"
    }
  ],
  "presets": [
    {
      "name": "Yuri About Split"
    }
  ]
}
{% endschema %}
