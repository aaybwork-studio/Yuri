<div class="color-{{ section.settings.color_scheme }} gradient" style="background-color: var(--color-brand-bg);">

  {%- comment -%}Mirrored Row 1: Text Left, Image Right{%- endcomment -%}
  <div class="yuri-mirrored-row border-b zen-border">
    <div class="yuri-mirrored-panel bg-[var(--color-brand-bg)] flex items-center justify-center">
      <div class="max-w-[480px]">
        {%- if section.settings.row1_caption != blank -%}
          <p class="font-sans text-xs uppercase tracking-widest mb-4" style="color: color-mix(in srgb, var(--color-brand-text) 70%, transparent); letter-spacing: 0.15em;">
            {{ section.settings.row1_caption | escape }}
          </p>
        {%- endif -%}
        {%- if section.settings.row1_heading != blank -%}
          <h2 class="font-serif text-3xl md:text-5xl font-light mb-6 lowercase" style="color: var(--color-brand-text); font-family: var(--font-serif); line-height: 1.2;">
            {{ section.settings.row1_heading | escape }}
          </h2>
        {%- endif -%}
        {%- if section.settings.row1_text != blank -%}
          <div class="font-sans text-sm md:text-base leading-relaxed mb-8" style="color: color-mix(in srgb, var(--color-brand-text) 70%, transparent);">
            {{ section.settings.row1_text }}
          </div>
        {%- endif -%}
        {%- if section.settings.row1_btn_label != blank and section.settings.row1_btn_link != blank -%}
          <a href="{{ section.settings.row1_btn_link }}" class="button button--secondary">
            {{ section.settings.row1_btn_label | escape }} →
          </a>
        {%- endif -%}
      </div>
    </div>
    
    <div class="flex-1 min-h-[40vh] md:min-h-screen relative overflow-hidden">
      {%- if section.settings.row1_image != blank -%}
        {{ section.settings.row1_image | image_url: width: 1500 | image_tag:
          class: 'absolute inset-0 w-full h-full object-cover',
          loading: 'lazy'
        }}
      {%- else -%}
        <img src="{{ 'yuri-browse-1.png' | asset_url }}" class="absolute inset-0 w-full h-full object-cover" alt="YURI Zen Browse Image 1" loading="lazy" width="1024" height="1024">
      {%- endif -%}
    </div>
  </div>

  {%- comment -%}Mirrored Row 2: Image Left, Text Right{%- endcomment -%}
  <div class="yuri-mirrored-row is-reversed border-b zen-border">
    <div class="yuri-mirrored-panel bg-[var(--color-brand-bg)] flex items-center justify-center">
      <div class="max-w-[480px]">
        {%- if section.settings.row2_caption != blank -%}
          <p class="font-sans text-xs uppercase tracking-widest mb-4" style="color: color-mix(in srgb, var(--color-brand-text) 70%, transparent); letter-spacing: 0.15em;">
            {{ section.settings.row2_caption | escape }}
          </p>
        {%- endif -%}
        {%- if section.settings.row2_heading != blank -%}
          <h2 class="font-serif text-3xl md:text-5xl font-light mb-6 lowercase" style="color: var(--color-brand-text); font-family: var(--font-serif); line-height: 1.2;">
            {{ section.settings.row2_heading | escape }}
          </h2>
        {%- endif -%}
        {%- if section.settings.row2_text != blank -%}
          <div class="font-sans text-sm md:text-base leading-relaxed mb-8" style="color: color-mix(in srgb, var(--color-brand-text) 70%, transparent);">
            {{ section.settings.row2_text }}
          </div>
        {%- endif -%}
        {%- if section.settings.row2_btn_label != blank and section.settings.row2_btn_link != blank -%}
          <a href="{{ section.settings.row2_btn_link }}" class="button button--secondary">
            {{ section.settings.row2_btn_label | escape }} →
          </a>
        {%- endif -%}
      </div>
    </div>
    
    <div class="flex-1 min-h-[40vh] md:min-h-screen relative overflow-hidden">
      {%- if section.settings.row2_image != blank -%}
        {{ section.settings.row2_image | image_url: width: 1500 | image_tag:
          class: 'absolute inset-0 w-full h-full object-cover',
          loading: 'lazy'
        }}
      {%- else -%}
        <img src="{{ 'yuri-browse-2.png' | asset_url }}" class="absolute inset-0 w-full h-full object-cover" alt="YURI Zen Browse Image 2" loading="lazy" width="1024" height="1024">
      {%- endif -%}
    </div>
  </div>

  {%- comment -%}Category List Section{%- endcomment -%}
  <div class="py-16 px-8 md:px-16" style="background-color: var(--color-brand-bg);">
    <div class="max-w-[1400px] mx-auto">
      {%- if section.settings.category_heading != blank -%}
        <h3 class="font-serif text-2xl md:text-3xl font-light mb-10 lowercase" style="color: var(--color-brand-text); font-family: var(--font-serif);">
          {{ section.settings.category_heading | escape }}
        </h3>
      {%- endif -%}

      <div class="yuri-categories-wrapper">
        <div class="flex gap-6 pb-4">
          {%- if section.blocks.size > 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'category' -%}
                <div class="flex-none w-[200px] md:w-[260px] flex flex-col group" {{ block.shopify_attributes }}>
                  <a href="{{ block.settings.link }}" class="block aspect-square w-full mb-4 overflow-hidden relative bg-[var(--color-brand-bg)]">
                    {%- if block.settings.image != blank -%}
                      {{ block.settings.image | image_url: width: 600 | image_tag:
                        class: 'w-full h-full object-cover transition-transform duration-500 group-hover:scale-105',
                        loading: 'lazy'
                      }}
                    {%- else -%}
                      {{ 'collection-1' | placeholder_svg_tag: 'w-full h-full object-cover opacity-60' }}
                    {%- endif -%}
                  </a>
                  <h4 class="font-sans text-sm font-medium hover:underline lowercase" style="color: var(--color-brand-text);">
                    <a href="{{ block.settings.link }}">
                      {{ block.settings.title | escape }}
                    </a>
                  </h4>
                </div>
              {%- endif -%}
            {%- endfor -%}
          {%- else -%}
            {%- comment -%}Onboarding mockups{%- endcomment -%}
            {%- assign mock_categories = "candles,fragrances,trays,accessories,gifts" | split: "," -%}
            {%- for mock in mock_categories -%}
              <div class="flex-none w-[200px] md:w-[260px] flex flex-col group">
                <div class="aspect-square w-full mb-4 overflow-hidden relative bg-[var(--color-brand-bg)] flex items-center justify-center">
                  {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'w-2/3 h-2/3 object-contain opacity-55' }}
                </div>
                <h4 class="font-sans text-sm font-medium hover:underline lowercase" style="color: var(--color-brand-text);">
                  <a href="#">
                    {{ mock }}
                  </a>
                </h4>
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>

</div>

{% schema %}
{
  "name": "Yuri Browse & Categories",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Mirrored Row 1 Details"
    },
    {
      "type": "image_picker",
      "id": "row1_image",
      "label": "Row 1 Image"
    },
    {
      "type": "text",
      "id": "row1_caption",
      "label": "Row 1 Caption",
      "default": "a moment for yourself"
    },
    {
      "type": "text",
      "id": "row1_heading",
      "label": "Row 1 Heading",
      "default": "many considered gestures"
    },
    {
      "type": "richtext",
      "id": "row1_text",
      "label": "Row 1 Text",
      "default": "<p>impeccable candles and delicate accessories, featuring finely tuned formulations and meticulously crafted ceramic ware.</p>"
    },
    {
      "type": "text",
      "id": "row1_btn_label",
      "label": "Row 1 Button Label",
      "default": "discover gifts"
    },
    {
      "type": "url",
      "id": "row1_btn_link",
      "label": "Row 1 Button Link",
      "default": "/collections/all"
    },
    {
      "type": "header",
      "content": "Mirrored Row 2 Details"
    },
    {
      "type": "image_picker",
      "id": "row2_image",
      "label": "Row 2 Image"
    },
    {
      "type": "text",
      "id": "row2_caption",
      "label": "Row 2 Caption",
      "default": "delightful home scents"
    },
    {
      "type": "text",
      "id": "row2_heading",
      "label": "Row 2 Heading",
      "default": "the fragrance finder"
    },
    {
      "type": "richtext",
      "id": "row2_text",
      "label": "Row 2 Text",
      "default": "<p>discover the ideal scented creations for your home environment. let us guide you through our botanicals.</p>"
    },
    {
      "type": "text",
      "id": "row2_btn_label",
      "label": "Row 2 Button Label",
      "default": "find your scent"
    },
    {
      "type": "url",
      "id": "row2_btn_link",
      "label": "Row 2 Button Link",
      "default": "/collections/all"
    },
    {
      "type": "header",
      "content": "Category Slider Details"
    },
    {
      "type": "text",
      "id": "category_heading",
      "label": "Category Slider Heading",
      "default": "browse by category"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Category Name"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Category Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Yuri Browse & Categories"
    }
  ]
}
{% endschema %}
