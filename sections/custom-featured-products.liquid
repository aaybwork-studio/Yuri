{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding py-16 px-8 md:px-16" style="background-color: var(--color-warm-white);">
  <div class="max-w-[1400px] mx-auto relative">
    
    {%- comment -%}Section Header{%- endcomment -%}
    <div class="text-center mb-12 max-w-[800px] mx-auto">
      {%- if section.settings.subheading != blank -%}
        <p class="font-sans text-sage text-xs uppercase tracking-widest mb-3" style="color: var(--color-sage); letter-spacing: 0.15em;">
          {{ section.settings.subheading | escape }}
        </p>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="font-serif text-forest text-2xl md:text-4xl font-light mb-4 lowercase" style="color: var(--color-forest); font-family: var(--font-serif);">
          {{ section.settings.title | escape }}
        </h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="font-sans text-sage text-sm md:text-base leading-relaxed" style="color: var(--color-sage);">
          {{ section.settings.description | escape }}
        </p>
      {%- endif -%}
    </div>

    {%- comment -%}Scroll Wrapper{%- endcomment -%}
    <div class="relative group">
      
      {%- comment -%}Scroll Arrows{%- endcomment -%}
      <button class="absolute -left-4 md:-left-8 top-1/2 -translate-y-1/2 z-30 bg-warm-white/80 border border-forest/10 p-3 rounded-full opacity-0 group-hover:opacity-100 transition-opacity hidden md:flex items-center justify-center cursor-pointer hover:bg-forest hover:text-warm-white" 
              id="ScrollPrev-{{ section.id }}"
              aria-label="Previous products"
              style="background-color: rgba(250, 247, 242, 0.8); border-color: rgba(44, 58, 46, 0.1);">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
        </svg>
      </button>
      
      <button class="absolute -right-4 md:-right-8 top-1/2 -translate-y-1/2 z-30 bg-warm-white/80 border border-forest/10 p-3 rounded-full opacity-0 group-hover:opacity-100 transition-opacity hidden md:flex items-center justify-center cursor-pointer hover:bg-forest hover:text-warm-white" 
              id="ScrollNext-{{ section.id }}"
              aria-label="Next products"
              style="background-color: rgba(250, 247, 242, 0.8); border-color: rgba(44, 58, 46, 0.1);">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
        </svg>
      </button>

      {%- comment -%}Scroll Container{%- endcomment -%}
      <div class="yuri-scroll-container pb-6" id="ScrollContainer-{{ section.id }}">
        
        {%- assign collection = section.settings.collection -%}
        {%- if collection != blank and collection.all_products_count > 0 -%}
          {%- for product in collection.products limit: section.settings.products_to_show -%}
            <div class="yuri-scroll-item">
              <div class="yuri-card-floating transition-all duration-300 flex flex-col h-full text-center">
                
                {%- comment -%}Product Image{%- endcomment -%}
                <a href="{{ product.url }}" class="block relative aspect-square w-full mb-6 overflow-hidden bg-transparent">
                  {%- if product.featured_media != blank -%}
                    {{ product.featured_media | image_url: width: 600 | image_tag:
                      class: 'w-full h-full object-contain transition-transform duration-700 hover:scale-105',
                      loading: 'lazy'
                    }}
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-cover bg-sand-cream' }}
                  {%- endif -%}
                </a>

                {%- comment -%}Product Info{%- endcomment -%}
                <div class="flex-grow flex flex-col items-center">
                  <h3 class="font-serif text-lg text-forest mb-2 font-light lowercase" style="font-family: var(--font-serif); color: var(--color-forest);">
                    <a href="{{ product.url }}" class="hover:underline">
                      {{ product.title | escape }}
                    </a>
                  </h3>
                  
                  <p class="font-sans text-xs text-sage mb-3 max-w-[280px]" style="color: var(--color-sage);">
                    {%- if product.metafields.custom.short_description != blank -%}
                      {{ product.metafields.custom.short_description | escape }}
                    {%- else -%}
                      {{ product.description | strip_html | truncatewords: 8 }}
                    {%- endif -%}
                  </p>
                  
                  <div class="text-xs text-sage mb-4 flex items-center gap-2" style="color: var(--color-sage);">
                    {%- unless product.has_only_default_variant -%}
                      <span>{{ product.selected_or_first_available_variant.title | escape }}</span>
                      <span class="w-1 h-1 rounded-full bg-sage/30"></span>
                    {%- endunless -%}
                    <span>{{ product.price | money }}</span>
                  </div>
                </div>

                {%- comment -%}Add to Cart Form{%- endcomment -%}
                <div class="mt-auto">
                  <product-form class="product-form" data-section-id="{{ section.id }}">
                    <div class="product-form__error-message-wrapper" role="alert" hidden>
                      <span class="product-form__error-message"></span>
                    </div>
                    
                    {%- form 'product', product, id: product_form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
                      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" class="product-variant-id">
                      <button type="submit" name="add" class="button button--primary w-full py-3 hover:bg-forest/90"
                              {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}>
                        <span>
                          {%- if product.selected_or_first_available_variant.available -%}
                            add to cart
                          {%- else -%}
                            sold out
                          {%- endif -%}
                        </span>
                        {%- render 'loading-spinner' -%}
                      </button>
                    {%- endform -%}
                  </product-form>
                </div>

              </div>
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- comment -%}Onboarding state{%- endcomment -%}
          {%- for i in (1..4) -%}
            <div class="yuri-scroll-item">
              <div class="yuri-card-floating transition-all duration-300 flex flex-col h-full text-center">
                <div class="aspect-square w-full mb-6 overflow-hidden bg-sand-cream flex items-center justify-center">
                  {{ 'product-' | append: i | placeholder_svg_tag: 'w-2/3 h-2/3 object-contain opacity-60' }}
                </div>
                <div class="flex-grow flex flex-col items-center">
                  <h3 class="font-serif text-lg text-forest mb-2 font-light lowercase" style="font-family: var(--font-serif);">
                    sample botanical product {{ i }}
                  </h3>
                  <p class="font-sans text-xs text-sage mb-3 max-w-[280px]">
                    natural scent spaces and elegant accessories for everyday comfort.
                  </p>
                  <div class="text-xs text-sage mb-4">
                    <span>9.3 oz</span>
                    <span class="mx-1.5">•</span>
                    <span>$45.00</span>
                  </div>
                </div>
                <button class="button button--primary w-full py-3" disabled>
                  add to cart
                </button>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
        
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('ScrollContainer-{{ section.id }}');
    const prevBtn = document.getElementById('ScrollPrev-{{ section.id }}');
    const nextBtn = document.getElementById('ScrollNext-{{ section.id }}');
    
    if (!container || !prevBtn || !nextBtn) return;
    
    function getScrollAmount() {
      const card = container.querySelector('.yuri-scroll-item');
      if (!card) return 300;
      return card.offsetWidth + 20; // card width + gap
    }
    
    prevBtn.addEventListener('click', () => {
      container.scrollBy({
        left: -getScrollAmount(),
        behavior: 'smooth'
      });
    });
    
    nextBtn.addEventListener('click', () => {
      container.scrollBy({
        left: getScrollAmount(),
        behavior: 'smooth'
      });
    });
  });
</script>

{% schema %}
{
  "name": "Yuri Scroll Products",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "new and notable"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "revered formulations"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "natural scented candles and curated trays designed to elevate your sensory space."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 6,
      "label": "Products to Show"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Yuri Scroll Products"
    }
  ]
}
{% endschema %}
