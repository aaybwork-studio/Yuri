{%- liquid
  assign footer_bg = 'var(--color-accent-rose)'
  assign footer_text = 'var(--color-brand-bg)'
  if section.settings.card_accent_bg == 'gold'
    assign footer_bg = 'var(--color-accent-gold)'
    assign footer_text = 'var(--color-brand-text)'
  elsif section.settings.card_accent_bg == 'warm_white'
    assign footer_bg = 'var(--color-brand-bg)'
    assign footer_text = 'var(--color-brand-text)'
  endif
-%}

<div class="color-{{ section.settings.color_scheme }} gradient py-8 px-4 md:px-12" style="background-color: var(--color-brand-bg);">
  <div class="yuri-footer-card max-w-[1400px] mx-auto flex flex-col gap-12 py-8 px-8 md:py-12 md:px-20" style="background-color: {{ footer_bg }}; color: {{ footer_text }}; border-radius: 0;">
    
    {%- comment -%}Top Row: Newsletter Signup{%- endcomment -%}
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 pb-10" style="border-bottom: 1px solid color-mix(in srgb, {{ footer_text }} 10%, transparent);">
      {%- if section.settings.newsletter_text != blank -%}
        <h3 class="font-serif text-2xl md:text-3xl font-light mb-0 lowercase" style="color: {{ footer_text }}; font-family: var(--font-serif);">
          {{ section.settings.newsletter_text | escape }}
        </h3>
      {%- endif -%}
      
      <div class="w-full md:w-auto md:min-w-[480px]">
        {%- form 'customer', class: 'flex flex-col sm:flex-row gap-4 w-full' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="flex-grow relative">
            <input
              id="FooterNewsletter-{{ section.id }}"
              type="email"
              name="contact[email]"
              class="field__input w-full py-3 px-2 bg-transparent placeholder:opacity-40 focus:outline-none border-b"
              style="border-color: color-mix(in srgb, {{ footer_text }} 30%, transparent); color: {{ footer_text }};"
              value="{{ form.email }}"
              placeholder="email address"
              aria-required="true"
              autocorrect="off"
              autocapitalize="off"
              autocomplete="email"
              {% if form.errors %}
                autofocus
                aria-invalid="true"
                aria-describedby="ContactFooter-success"
              {% elsif form.posted_successfully? %}
                aria-describedby="ContactFooter-success"
              {% endif %}
              required
            >
          </div>
          <button type="submit" class="button px-8 py-3 uppercase tracking-wider text-xs font-semibold hover:opacity-90"
                  style="background-color: {{ footer_text }} !important; color: {{ footer_bg }} !important; border-color: {{ footer_text }} !important;"
                  name="commit">
            submit
          </button>
          
          {%- if form.posted_successfully? -%}
            <p class="font-sans text-xs mt-2 absolute bottom-[-24px] left-0" style="color: color-mix(in srgb, {{ footer_text }} 80%, transparent);" id="ContactFooter-success">
              thank you for subscribing.
            </p>
          {%- endif -%}
        {%- endform -%}
      </div>
    </div>

    {%- comment -%}Middle Row: Large Centered Wordmark{%- endcomment -%}
    <div class="flex justify-center items-center py-8">
      <a href="{{ routes.root_url }}" class="block max-w-[250px] md:max-w-[320px] transition-opacity hover:opacity-95">
        <img src="{{ 'yuri-wordmark.svg' | asset_url }}" 
             alt="{{ shop.name }}" 
             style="width: 100%; height: auto; display: block; {% if footer_text == 'var(--color-brand-bg)' %}filter: brightness(0) invert(1);{% endif %}" 
             loading="lazy"
             width="969"
             height="236">
      </a>
    </div>

    {%- comment -%}Bottom Row: Menus and Social Icons{%- endcomment -%}
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end gap-8 pt-10" style="border-top: 1px solid color-mix(in srgb, {{ footer_text }} 10%, transparent);">
      
      {%- comment -%}Left Menu{%- endcomment -%}
      <div class="flex flex-wrap gap-x-8 gap-y-2">
        {%- assign left_menu = section.settings.left_menu -%}
        {%- if left_menu != blank -%}
          {%- for link in left_menu.links -%}
            <a href="{{ link.url }}" class="font-sans text-sm tracking-wide hover:underline lowercase">
              {{ link.title | escape }}
            </a>
          {%- endfor -%}
        {%- else -%}
          {%- comment -%}Onboarding links{%- endcomment -%}
          <a href="#" class="font-sans text-sm tracking-wide hover:underline lowercase">wholesale</a>
          <a href="#" class="font-sans text-sm tracking-wide hover:underline lowercase">terms of use</a>
          <a href="#" class="font-sans text-sm tracking-wide hover:underline lowercase">faq</a>
        {%- endif -%}
      </div>

      {%- comment -%}Right Menu + Socials{%- endcomment -%}
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-8 w-full sm:w-auto">
        <div class="flex flex-wrap gap-x-8 gap-y-2">
          {%- assign right_menu = section.settings.right_menu -%}
          {%- if right_menu != blank -%}
            {%- for link in right_menu.links -%}
              <a href="{{ link.url }}" class="font-sans text-sm tracking-wide hover:underline lowercase">
                {{ link.title | escape }}
              </a>
            {%- endfor -%}
          {%- else -%}
            {%- comment -%}Onboarding links{%- endcomment -%}
            <a href="#" class="font-sans text-sm tracking-wide hover:underline lowercase">shop</a>
            <a href="#" class="font-sans text-sm tracking-wide hover:underline lowercase">about us</a>
            <a href="#" class="font-sans text-sm tracking-wide hover:underline lowercase">contact us</a>
            <a href="#" class="font-sans text-sm tracking-wide hover:underline lowercase">store locator</a>
          {%- endif -%}
        </div>

        {%- comment -%}Social Icons{%- endcomment -%}
        {%- if section.settings.show_social -%}
          <div class="flex gap-4">
            {%- if settings.social_instagram_link != blank or true -%}
              <a href="{{ settings.social_instagram_link | default: '#' }}" class="transition-colors hover:opacity-100" style="color: color-mix(in srgb, {{ footer_text }} 75%, transparent);" aria-label="Instagram">
                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="w-5 h-5" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              </a>
            {%- endif -%}
            {%- if settings.social_facebook_link != blank or true -%}
              <a href="{{ settings.social_facebook_link | default: '#' }}" class="transition-colors hover:opacity-100" style="color: color-mix(in srgb, {{ footer_text }} 75%, transparent);" aria-label="Facebook">
                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="w-5 h-5" viewBox="0 0 24 24">
                  <path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/>
                </svg>
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
      
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Yuri Brand Footer",
  "tag": "footer",
  "class": "section-footer",
  "settings": [
    {
      "type": "select",
      "id": "card_accent_bg",
      "label": "Card Accent Background",
      "options": [
        {
          "value": "rose",
          "label": "Rose"
        },
        {
          "value": "gold",
          "label": "Gold"
        },
        {
          "value": "warm_white",
          "label": "Warm White"
        }
      ],
      "default": "rose"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "newsletter_text",
      "label": "Newsletter Heading",
      "default": "sign up and get 10% off"
    },
    {
      "type": "link_list",
      "id": "left_menu",
      "label": "Left Bottom Menu"
    },
    {
      "type": "link_list",
      "id": "right_menu",
      "label": "Right Bottom Menu"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show Social Icons",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Yuri Brand Footer"
    }
  ]
}
{% endschema %}
