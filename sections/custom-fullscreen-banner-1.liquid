<div class="fullscreen-banner w-full min-h-screen relative flex flex-col justify-end bg-[#faf8f1] overflow-hidden py-12 px-6 sm:px-12" id="Banner-{{ section.id }}">
  <div class="w-full h-full absolute inset-0 z-10">
    {% if section.settings.link != blank %}
      <a href="{{ section.settings.link }}" class="w-full h-full block">
    {% endif %}

    {% if section.settings.video_url != blank %}
      <video class="w-full h-full object-cover" autoplay loop muted playsinline>
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {% else %}
      {% if section.settings.image_desktop != blank %}
        {{ section.settings.image_desktop | image_url: width: 2000 | image_tag: 
          class: 'w-full h-full object-cover hidden sm:block',
          loading: 'lazy'
        }}
      {% else %}
        {%- assign desktop_fallback = 'yuri-hero-2.png' | asset_url -%}
        <img src="{{ desktop_fallback }}" class="w-full h-full object-cover hidden sm:block" alt="" loading="lazy" width="1600" height="1200">
      {% endif %}

      {% if section.settings.image_mobile != blank %}
        {{ section.settings.image_mobile | image_url: width: 1000 | image_tag: 
          class: 'w-full h-full object-cover sm:hidden',
          loading: 'lazy'
        }}
      {% else %}
        {%- assign mobile_fallback = 'yuri-hero-2.png' | asset_url -%}
        <img src="{{ mobile_fallback }}" class="w-full h-full object-cover sm:hidden" alt="" loading="lazy" width="800" height="800">
      {% endif %}
    {% endif %}

    {% if section.settings.link != blank %}
      </a>
    {% endif %}
  </div>

  {% if section.settings.label_text != blank %}
    <div class="relative z-20 pointer-events-none mt-auto flex {{ section.settings.label_alignment }}">
      <p class="text-[10px] sm:text-[11px] tracking-[0.25em] font-sans font-light uppercase text-black bg-[#faf8f1] py-2 px-4 select-none m-0">
        {{ section.settings.label_text }}
      </p>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Yuri Fullscreen Banner 1",
  "tag": "section",
  "class": "section-fullscreen-banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Desktop Image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile Image"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Autoplay Video URL",
      "info": "Upload video to Shopify Files and paste URL here (MP4 format recommended)."
    },
    {
      "type": "text",
      "id": "label_text",
      "label": "Caption Label Text"
    },
    {
      "type": "select",
      "id": "label_alignment",
      "label": "Caption Label Alignment",
      "options": [
        { "value": "justify-start", "label": "Left" },
        { "value": "justify-center", "label": "Center" },
        { "value": "justify-end", "label": "Right" }
      ],
      "default": "justify-start"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link Destination"
    }
  ],
  "presets": [
    {
      "name": "Yuri Fullscreen Banner 1"
    }
  ]
}
{% endschema %}
