<div class="w-full h-screen relative overflow-hidden bg-[var(--color-brand-bg)]" id="FullscreenBanner-{{ section.id }}">
  {%- if section.settings.link != blank -%}
    <a href="{{ section.settings.link }}" class="absolute inset-0 z-20 block">
  {%- endif -%}

  {%- comment -%}Overlay{%- endcomment -%}
  <div class="absolute inset-0 z-10 pointer-events-none" style="background-color: rgba(0, 0, 0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});"></div>

  {%- comment -%}Media Container{%- endcomment -%}
  <div class="w-full h-full">
    {%- if section.settings.media_type == 'video' and section.settings.video_url != blank -%}
      <video class="w-full h-full object-cover" autoplay loop muted playsinline poster="{{ section.settings.image_desktop | image_url: width: 2000 }}">
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {%- else -%}
      {%- if section.settings.image_desktop != blank -%}
        <picture>
          {%- if section.settings.image_mobile != blank -%}
            <source media="(max-width: 767px)" srcset="{{ section.settings.image_mobile | image_url: width: 1000 }}">
          {%- endif -%}
          <source media="(min-width: 768px)" srcset="{{ section.settings.image_desktop | image_url: width: 2000 }}">
          {{ section.settings.image_desktop | image_url: width: 2000 | image_tag: 
            class: 'w-full h-full object-cover',
            loading: 'lazy'
          }}
        </picture>
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'w-full h-full object-cover bg-neutral-200 opacity-60' }}
      {%- endif -%}
    {%- endif -%}
  </div>

  {%- comment -%}Label Overlay{%- endcomment -%}
  {%- if section.settings.show_label and section.settings.label_text != blank -%}
    {%- assign pos_class = 'bottom-8 left-8' -%}
    {%- if section.settings.label_position == 'top-left' -%}
      {%- assign pos_class = 'top-24 left-8' -%}
    {%- elsif section.settings.label_position == 'top-right' -%}
      {%- assign pos_class = 'top-24 right-8 text-right' -%}
    {%- elsif section.settings.label_position == 'bottom-right' -%}
      {%- assign pos_class = 'bottom-8 right-8 text-right' -%}
    {%- endif -%}
    
    <div class="absolute {{ pos_class }} z-30 pointer-events-none select-none max-w-[80vw]">
      <span class="font-sans text-[1.1rem] tracking-[0.2em] uppercase text-white font-light" style="font-family: var(--font-sans); font-size: 1.1rem; letter-spacing: 0.2em;">
        {{ section.settings.label_text | escape }}
      </span>
    </div>
  {%- endif -%}

  {%- if section.settings.link != blank -%}
    </a>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Yuri Fullscreen Media 2",
  "tag": "section",
  "class": "section-fullscreen",
  "settings": [
    {
      "type": "select",
      "id": "media_type",
      "label": "Media Type",
      "options": [
        {
          "value": "image",
          "label": "Image"
        },
        {
          "value": "video",
          "label": "Video (MP4)"
        }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Desktop Image / Video Poster"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile Image Override"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "MP4 Video URL",
      "info": "Paste link to an MP4 video (e.g. from S3 or Shopify Files)"
    },
    {
      "type": "checkbox",
      "id": "show_label",
      "label": "Show Label",
      "default": true
    },
    {
      "type": "text",
      "id": "label_text",
      "label": "Label Text",
      "default": "pot pourri mineral totem"
    },
    {
      "type": "select",
      "id": "label_position",
      "label": "Label Position",
      "options": [
        {
          "value": "top-left",
          "label": "Top Left"
        },
        {
          "value": "top-right",
          "label": "Top Right"
        },
        {
          "value": "bottom-left",
          "label": "Bottom Left"
        },
        {
          "value": "bottom-right",
          "label": "Bottom Right"
        }
      ],
      "default": "bottom-left"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Dark Overlay Opacity",
      "default": 10
    },
    {
      "type": "url",
      "id": "link",
      "label": "Banner Click Link"
    }
  ],
  "presets": [
    {
      "name": "Yuri Fullscreen Media 2"
    }
  ]
}
{% endschema %}
