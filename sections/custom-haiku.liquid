<section class="yuri-haiku-section w-full min-h-screen bg-[#faf8f1] dark:bg-black text-black dark:text-white flex flex-col items-center justify-center relative overflow-hidden" id="Haiku-{{ section.id }}" data-haiku-section>
  <div class="haiku-container flex flex-col items-center justify-center text-center space-y-10 max-w-lg px-6 py-24">
    <!-- Japanese Text Pair Display (Same font as header/hero: Dia) -->
    <div class="japanese-display h-32 sm:h-40 flex items-center justify-center select-none">
      <span class="japanese-pair text-[64px] sm:text-[80px] font-sans font-light tracking-[0.2em] leading-none transition-all duration-300" data-haiku-ja>
        とも
      </span>
    </div>
    
    <!-- English Subtitle in Warm Yellow/Ochre -->
    <div class="english-display h-12 flex items-center justify-center select-none">
      <p class="english-sub text-[10px] sm:text-[11px] tracking-[0.35em] font-sans uppercase text-[#d9a752] font-light transition-all duration-300" data-haiku-en>
        a single flame
      </p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Yuri Custom Haiku",
  "tag": "section",
  "class": "section-yuri-haiku",
  "settings": [],
  "presets": [
    {
      "name": "Yuri Custom Haiku"
    }
  ]
}
{% endschema %}
