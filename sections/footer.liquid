<footer class="theme-footer w-full bg-[#faf8f1] border-t border-neutral-100 py-16 px-6 font-sans text-[10px] tracking-[0.2em] uppercase text-neutral-600">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-12 items-start text-center md:text-left">
    <!-- Links Column 1 -->
    <div class="space-y-3">
      <h3 class="text-black font-normal tracking-[0.2em]">CUSTOMER CARE</h3>
      <ul class="space-y-2 normal-case tracking-wider text-[11px] font-light text-neutral-500">
        <li><a href="#" class="hover:text-black transition-colors">CONTACT US</a></li>
        <li><a href="#" class="hover:text-black transition-colors">SHIPPING & RETURNS</a></li>
        <li><a href="#" class="hover:text-black transition-colors">TERMS & PRIVACY</a></li>
      </ul>
    </div>

    <!-- Links Column 2 -->
    <div class="space-y-3">
      <h3 class="text-black font-normal tracking-[0.2em]">BOUTIQUE</h3>
      <ul class="space-y-2 normal-case tracking-wider text-[11px] font-light text-neutral-500">
        <li><a href="#" class="hover:text-black transition-colors">OUR STORY</a></li>
        <li><a href="#" class="hover:text-black transition-colors">STOCKISTS</a></li>
        <li><a href="#" class="hover:text-black transition-colors">JOURNAL</a></li>
      </ul>
    </div>

    <!-- Newsletter -->
    <div class="space-y-4">
      <h3 class="text-black font-normal tracking-[0.2em]">NEWSLETTER</h3>
      <p class="normal-case tracking-wider text-[11px] font-light text-neutral-500">Subscribe to receive updates on collections and stories.</p>
      
      {% form 'customer', class: 'footer-newsletter-form flex items-center border-b border-black py-1' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <input type="email" name="contact[email]" placeholder="YOUR EMAIL" class="bg-transparent text-[11px] tracking-widest outline-none border-0 text-black placeholder-neutral-400 w-full rounded-none" required>
        <button type="submit" class="text-[10px] tracking-[0.2em] uppercase text-black hover:opacity-60 transition-opacity">JOIN</button>
      {% endform %}
    </div>
  </div>

  <div class="max-w-7xl mx-auto pt-16 mt-16 border-t border-neutral-100 flex flex-col md:flex-row items-center justify-between text-neutral-400 text-[9px] tracking-wider text-center md:text-left gap-4">
    <span>© {{ 'now' | date: '%Y' }} {{ shop.name }} OFFICIEL. ALL RIGHTS RESERVED.</span>
    <span>DESIGN INSPIRED BY MAD ET LEN</span>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": []
}
{% endschema %}
