<header class="theme-header fixed top-0 left-0 w-full z-50 transition-all duration-300 border-b border-transparent bg-transparent" data-header>
  <div class="max-w-7xl mx-auto px-6 h-12 flex items-center justify-between">
    <!-- Left: Menu Link -->
    <div class="flex-1 flex justify-start">
      <a href="#" class="header-link text-[11px] tracking-[0.2em] font-sans font-light uppercase text-black hover:opacity-60 transition-opacity">MENU</a>
    </div>

    <!-- Center: Logo -->
    <div class="flex-none flex justify-center">
      <a href="{{ routes.root_url }}" class="header-logo block text-black h-[14px] sm:h-[16px] w-auto fill-current flex items-center">
        {% render 'yuri-wordmark-logo' %}
      </a>
    </div>

    <!-- Right: Bag Link -->
    <div class="flex-1 flex justify-end">
      <a href="{{ routes.cart_url }}" class="header-link text-[11px] tracking-[0.2em] font-sans font-light uppercase text-black hover:opacity-60 transition-opacity">
        BAG ({{ cart.item_count }})
      </a>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": []
}
{% endschema %}
