<header class="theme-header fixed top-0 left-0 w-full z-50 transition-all duration-300 border-b border-transparent bg-transparent" data-header>
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
    <!-- Left: Menu Button -->
    <div class="flex-1 flex justify-start">
      <button type="button" class="header-link text-[11px] tracking-[0.2em] font-sans font-light uppercase text-black hover:opacity-60 transition-opacity bg-transparent border-0 cursor-pointer p-0" data-menu-toggle>
        MENU
      </button>
    </div>

    <!-- Center: Logo -->
    <div class="flex-none flex justify-center">
      <a href="{{ routes.root_url }}" class="header-logo block text-black h-[14px] sm:h-[16px] w-auto fill-current flex items-center">
        {% render 'yuri-wordmark-logo' %}
      </a>
    </div>

    <!-- Right: Bag Link -->
    <div class="flex-1 flex justify-end">
      <a href="{{ routes.cart_url }}" class="header-link text-[11px] tracking-[0.2em] font-sans font-light uppercase text-black hover:opacity-60 transition-opacity" data-cart-toggle>
        BAG (<span data-cart-count>{{ cart.item_count }}</span>)
      </a>
    </div>
  </div>
</header>

<!-- Slide-out Navigation Drawer -->
<div class="fixed inset-0" data-menu-overlay></div>

<div class="flex flex-col justify-between p-8 sm:p-12" data-menu-drawer>
  <!-- Drawer Body: Categories of products (top) -->
  <div class="flex-none overflow-y-auto">
    <nav class="flex flex-col space-y-6">
      <a href="#" class="text-[12px] sm:text-[13px] tracking-[0.25em] font-sans font-light uppercase text-black hover:opacity-60 transition-opacity block">Candles</a>
      <a href="#" class="text-[12px] sm:text-[13px] tracking-[0.25em] font-sans font-light uppercase text-black hover:opacity-60 transition-opacity block">Scents</a>
      <a href="#" class="text-[12px] sm:text-[13px] tracking-[0.25em] font-sans font-light uppercase text-black hover:opacity-60 transition-opacity block">Fragrances</a>
      <a href="#" class="text-[12px] sm:text-[13px] tracking-[0.25em] font-sans font-light uppercase text-black hover:opacity-60 transition-opacity block">Incense</a>
      <a href="#" class="text-[12px] sm:text-[13px] tracking-[0.25em] font-sans font-light uppercase text-black hover:opacity-60 transition-opacity block">Diffusers</a>
    </nav>
  </div>

  <!-- Drawer Footer: bottom items separated by gap -->
  <div class="flex-none pt-8 space-y-6">
    <!-- Secondary Menu Links -->
    <div class="space-y-4">
      <a href="#" class="text-[11px] sm:text-[12px] tracking-[0.2em] font-sans font-light uppercase text-black hover:opacity-60 transition-opacity block py-0.5">About</a>
      <a href="#" class="text-[11px] sm:text-[12px] tracking-[0.2em] font-sans font-light uppercase text-black hover:opacity-60 transition-opacity block py-0.5">Contact</a>
    </div>

    <!-- Account / Sign In -->
    <div class="flex items-center space-x-3 text-[10px] tracking-[0.2em] font-sans font-light text-black">
      <a href="{{ routes.account_url }}" class="hover:opacity-60 transition-opacity">Account</a>
      <span class="text-neutral-300 font-light">/</span>
      <a href="{{ routes.account_login_url }}" class="hover:opacity-60 transition-opacity">Sign In</a>
    </div>

    <!-- Search -->
    <div>
      <a href="{{ routes.search_url }}" class="text-[10px] tracking-[0.2em] font-sans font-light uppercase text-black hover:opacity-60 transition-opacity block py-0.5">
        Search
      </a>
    </div>

    <!-- Experience -->
    <div>
      <a href="/pages/experience" class="text-[10px] tracking-[0.2em] font-sans font-light uppercase text-black hover:opacity-60 transition-opacity block py-0.5">
        Experience
      </a>
    </div>

    <!-- Country & Language Selection Buttons -->
    <div class="pt-6 border-t border-black/5 space-y-4 text-[9px] tracking-[0.15em] font-sans font-light text-neutral-500 uppercase">
      <div>
        Country / Region: 
        <button type="button" class="text-black hover:opacity-60 transition-opacity font-light bg-transparent border-0 cursor-pointer p-0 ml-1">
          France (EUR €)
        </button>
      </div>
      <div class="flex items-center space-x-2">
        <span>Language:</span>
        <button type="button" class="text-black hover:opacity-60 transition-opacity font-medium bg-transparent border-0 cursor-pointer p-0">EN</button>
        <span class="text-neutral-200">|</span>
        <button type="button" class="text-neutral-400 hover:text-black transition-colors font-light bg-transparent border-0 cursor-pointer p-0">JP</button>
      </div>
    </div>
  </div>
</div>

<!-- Slide-out Cart Drawer -->
<div class="fixed inset-0" data-cart-overlay></div>

<div class="flex flex-col justify-between" data-cart-drawer>
  <!-- Drawer Header -->
  <div class="h-12 px-6 flex items-center justify-between border-b border-black/5">
    <span class="text-[10px] tracking-[0.2em] font-sans font-light uppercase text-black" data-cart-title>BAG ({{ cart.item_count }})</span>
    <button type="button" class="text-[10px] tracking-[0.2em] font-sans font-light uppercase text-black hover:opacity-60 transition-opacity bg-transparent border-0 cursor-pointer p-0" data-cart-close>
      CLOSE
    </button>
  </div>

  <!-- Drawer Body -->
  <div class="flex-1 overflow-y-auto py-6 px-6" data-cart-items>
    <!-- Rendered Dynamically via JS -->
  </div>

  <!-- Drawer Footer -->
  <div class="p-6 border-t border-black/5 space-y-4" data-cart-footer>
    <div class="flex justify-between text-[11px] tracking-[0.15em] font-sans font-light text-black">
      <span>SUBTOTAL</span>
      <span data-cart-subtotal>{{ cart.total_price | money }}</span>
    </div>
    <p class="text-[9px] text-neutral-400 normal-case tracking-normal leading-normal">
      Taxes and shipping calculated at checkout.
    </p>
    <a href="/checkout" class="block w-full bg-black text-[#faf8f1] hover:bg-neutral-900 text-center py-3.5 text-[10px] tracking-[0.2em] uppercase font-sans font-light rounded-none transition-colors duration-300">
      CHECKOUT
    </a>
  </div>
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
