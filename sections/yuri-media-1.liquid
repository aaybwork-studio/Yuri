{%- liquid
  assign layout = section.settings.layout | default: 'fullsize'
  assign product_handle = section.settings.product
  
  if product_handle != blank
    assign product_obj = all_products[product_handle]
    assign media_link = product_obj.url
    assign default_image = product_obj.featured_image
    assign default_caption = product_obj.title
  else
    assign media_link = section.settings.link
    assign default_image = nil
    assign default_caption = ""
  endif

  if section.settings.image != blank
    assign image = section.settings.image
  else
    assign image = default_image
  endif

  assign video_url = section.settings.video_url

  if section.settings.caption != blank
    assign caption = section.settings.caption
  else
    assign caption = default_caption
  endif

  assign body_text = section.settings.body_text
-%}

<div class="yuri-media yuri-media--{{ layout }} w-full bg-[#faf8f1]" id="Media-{{ section.id }}">
  <div class="yuri-media-inner
    {%- if layout == 'portrait' %} max-w-[750px] mx-auto px-6 py-12
    {%- elsif layout == 'landscape' %} max-w-[1100px] mx-auto px-6 py-12
    {%- endif -%}">

    {%- if media_link -%}<a href="{{ media_link }}" class="yuri-media-link block">{%- endif -%}

    <div class="yuri-media-content w-full overflow-hidden
      {%- if layout == 'portrait' %} aspect-[3/4]
      {%- elsif layout == 'landscape' %} aspect-[16/10]
      {%- endif -%}">

      {%- if video_url != blank -%}
        <video
          class="w-full h-full object-cover"
          autoplay
          loop
          muted
          playsinline
        >
          <source src="{{ video_url }}" type="video/mp4">
        </video>

      {%- elsif image != blank -%}
        {{
          image
          | image_url: width: 2000
          | image_tag:
            class: 'w-full h-full object-cover',
            loading: 'lazy',
            widths: '375, 750, 1100, 1500, 2000'
        }}

      {%- else -%}
        <img
          src="{{ 'yuri-media-1.png' | asset_url }}"
          alt=""
          class="w-full h-full object-cover"
          loading="lazy"
          width="1400"
          height="1000"
        >
      {%- endif -%}
    </div>

    {%- if caption != blank -%}
      <p class="yuri-media-caption text-[10px] sm:text-[11px] tracking-[0.2em] font-sans font-light uppercase text-black mt-3
        {%- if layout == 'fullsize' %} px-6{%- endif -%}">
        {{- caption -}}
      </p>
    {%- endif -%}

    {%- if body_text != blank -%}
      <div class="yuri-media-body-text max-w-[650px] mx-auto text-center mt-6 px-6 text-[13px] sm:text-[14px] leading-[1.8] tracking-[0.05em] font-sans font-light text-black">
        {{- body_text -}}
      </div>
    {%- endif -%}

    {%- if media_link -%}</a>{%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Yuri Media 1",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "fullsize", "label": "Full Width (edge to edge)" },
        { "value": "portrait", "label": "Centered Portrait Card" },
        { "value": "landscape", "label": "Centered Landscape Card" }
      ],
      "default": "fullsize"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product Link"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Custom Link Override"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Custom Image Override"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL (MP4)",
      "info": "Upload to Shopify Files and paste URL here."
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Custom Caption Override"
    },
    {
      "type": "text",
      "id": "body_text",
      "label": "Body Text Banner"
    }
  ],
  "presets": [
    {
      "name": "Yuri Media 1"
    }
  ]
}
{% endschema %}
