<div class="collection-page max-w-7xl mx-auto px-4 py-24 md:py-32 font-sans text-xs tracking-widest uppercase text-black">
  <div class="text-center mb-16">
    <h1 class="text-sm font-normal tracking-[0.2em] uppercase m-0">{{ collection.title }}</h1>
    {% if collection.description != blank %}
      <div class="description text-neutral-500 max-w-xl mx-auto mt-4 normal-case text-[11px] font-light tracking-wide leading-relaxed">
        {{ collection.description }}
      </div>
    {% endif %}
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-x-8 gap-y-16">
    {% for product in collection.products %}
      <a href="{{ product.url }}" class="group block space-y-4 text-center">
        <div class="w-full aspect-[3/4] bg-neutral-100 overflow-hidden relative">
          {% if product.featured_image != blank %}
            <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title | escape }}" class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700" loading="lazy" width="{{ product.featured_image.width }}" height="{{ product.featured_image.height }}">
          {% else %}
            <div class="w-full h-full flex items-center justify-center bg-neutral-150">
              <span class="text-neutral-400 text-[10px]">NO IMAGE</span>
            </div>
          {% endif %}
        </div>
        <div class="space-y-1">
          <div class="text-xs font-normal tracking-widest group-hover:underline">{{ product.title }}</div>
          <div class="text-[10px] text-neutral-500">{{ product.price | money }}</div>
        </div>
      </a>
    {% empty %}
      <div class="col-span-full text-center py-24 text-neutral-400">
        NO PRODUCTS FOUND IN THIS COLLECTION
      </div>
    {% endfor %}
  </div>
</div>
