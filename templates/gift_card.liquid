{% layout none %}
<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Gift Card</title>
    {{ content_for_header }}
    {{ 'yuri-styles.css' | asset_url | stylesheet_tag }}
  </head>
  <body class="bg-[#faf8f1] text-black font-sans min-h-screen flex items-center justify-center p-6 text-center text-xs tracking-widest uppercase">
    <div class="max-w-md w-full border border-neutral-200 p-8 bg-white space-y-6">
      <h1 class="text-sm font-normal tracking-[0.2em]">{{ shop.name }}</h1>
      <h2 class="text-neutral-500">YOUR GIFT CARD</h2>
      <div class="text-lg tracking-widest font-normal my-4">{{ gift_card.balance | money }}</div>
      <div class="bg-neutral-50 py-3 px-4 border border-dashed border-neutral-300 font-mono select-all text-xs tracking-wide">
        {{ gift_card.code | format_code }}
      </div>
      <p class="text-neutral-400 normal-case tracking-normal text-[10px]">Use this code at checkout to redeem your gift card.</p>
    </div>
  </body>
</html>
