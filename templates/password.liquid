{% layout 'password' %}

<div class="max-w-md w-full text-center space-y-8 font-sans text-xs tracking-widest uppercase text-black py-12">
  <!-- Brand Logo -->
  <div class="h-[16px] sm:h-[18px] fill-current text-black flex items-center justify-center">
    {% render 'yuri-wordmark-logo' %}
  </div>

  <p class="text-neutral-500 font-light text-[11px] normal-case tracking-wide leading-relaxed">
    Our store will be opening soon. Please enter the store password to access.
  </p>

  {% form 'storefront_password', class: 'space-y-4 max-w-xs mx-auto' %}
    {{ form.errors | default_errors }}
    
    <div class="flex border-b border-black py-1">
      <input type="password" name="password" placeholder="ENTER PASSWORD" class="bg-transparent text-[11px] tracking-widest outline-none border-0 text-black placeholder-neutral-400 w-full rounded-none" required>
      <button type="submit" class="text-[10px] tracking-[0.2em] uppercase text-black hover:opacity-60 transition-opacity">ENTER</button>
    </div>
  {% endform %}
</div>
