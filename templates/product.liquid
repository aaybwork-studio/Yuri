<div class="product-page bg-[#faf8f1] min-h-screen text-black py-24 md:py-32">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20 items-start">
      
      <!-- Left: Scrollable Media Gallery (Span 7) -->
      <div class="lg:col-span-7 space-y-6">
        {% if product.images.size > 0 %}
          {% for image in product.images %}
            <div class="w-full bg-[#faf8f1] overflow-hidden">
              <img 
                src="{{ image.src | image_url: width: 1500 }}" 
                alt="{{ image.alt | escape }}" 
                class="w-full h-auto object-cover" 
                loading="lazy" 
                width="{{ image.width }}" 
                height="{{ image.height }}"
              >
            </div>
          {% endfor %}
        {% else %}
          <div class="w-full aspect-[3/4] bg-neutral-100 flex items-center justify-center">
            <span class="text-neutral-400 text-[10px] tracking-widest uppercase">NO IMAGE AVAILABLE</span>
          </div>
        {% endif %}
      </div>

      <!-- Right: Sticky Product Details (Span 5) -->
      <div class="lg:col-span-5 lg:sticky lg:top-24 space-y-8">
        <div>
          <!-- Scent / Product Title -->
          <h1 class="text-sm font-normal tracking-[0.2em] uppercase m-0 leading-tight">
            {{ product.title }}
          </h1>
          
          <!-- Price and Tax Info -->
          <p class="text-[11px] tracking-widest uppercase text-neutral-500 mt-2 font-sans">
            {{ product.price | money }}
            <span class="text-[9px] text-neutral-400 ml-1">Taxes included</span>
          </p>
        </div>

        <!-- Rich Text Description -->
        {% if product.description != blank %}
          <div class="product-description pr-4">
            {{ product.description }}
          </div>
        {% endif %}

        <!-- Add to Bag Form -->
        <form method="post" action="{{ routes.cart_add_url }}" class="space-y-6 pt-4 border-t border-black/5">
          {% if product.variants.size > 1 %}
            <div class="space-y-2">
              <label class="block text-[9px] tracking-[0.2em] uppercase text-neutral-400">Select Scent / Variant</label>
              <select name="id" class="w-full border-b border-black/10 focus:border-black bg-transparent py-2 outline-none font-sans text-xs tracking-widest text-black rounded-none transition-colors">
                {% for variant in product.variants %}
                  <option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected{% endif %}>
                    {{ variant.title }} - {{ variant.price | money }}
                  </option>
                {% endfor %}
              </select>
            </div>
          {% else %}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          {% endif %}

          <button 
            type="submit" 
            class="w-full bg-black text-[#faf8f1] hover:bg-neutral-900 hover:text-white py-3.5 text-center text-[10px] tracking-[0.2em] uppercase font-sans font-light rounded-none transition-colors duration-300 border border-black"
          >
            ADD TO BAG
          </button>
        </form>
      </div>

    </div>
  </div>
</div>
